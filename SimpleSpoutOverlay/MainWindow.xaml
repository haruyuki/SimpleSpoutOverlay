<Window x:Class="SimpleSpoutOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SimpleSpoutOverlay.UI.Converters"
        xmlns:behaviors="clr-namespace:SimpleSpoutOverlay.UI.Behaviors"
        mc:Ignorable="d"
        Title="Spout Text Overlay"
        Height="840"
        Width="1460"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.WindowBackground}"
        MinHeight="700"
        MinWidth="1200"
        xmlns:viewModels="clr-namespace:SimpleSpoutOverlay.UI.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel, IsDesignTimeCreatable=False}">
    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:HasValueToBoolConverter x:Key="HasValueToBoolConverter" />
        <converters:SelectedLayerToVisibilityConverter x:Key="SelectedLayerToVisibilityConverter" />
        <converters:SingleLineTextConverter x:Key="SingleLineTextConverter" />

        <Style x:Key="PropertyRowStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="PropertyRowCompactStyle" TargetType="StackPanel" BasedOn="{StaticResource PropertyRowStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="LayerSectionSpacingStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="TextLayerSectionStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTextLayerSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImageLayerSectionStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsImageLayerSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PropertySliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="behaviors:SliderUndoGestureBehavior.IsEnabled" Value="True" />
        </Style>

        <Style x:Key="PropertyNumericTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource NumericValueEditorStyle}">
            <Setter Property="ToolTip" Value="Click to type a value" />
            <Setter Property="behaviors:NumericEditorBehavior.IsEnabled" Value="True" />
        </Style>

        <Style x:Key="PropertySectionExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>

        <Style x:Key="AlignmentToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}" Key="Z" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding RedoCommand}" Key="Y" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding SaveSetupCommand}" Key="S" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding LoadSetupCommand}" Key="O" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding AddLayerCommand}" Key="N" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding DeleteLayerCommand}" Key="Delete" Modifiers="Ctrl" />
    </Window.InputBindings>

    <Grid Margin="14" Background="{DynamicResource Brush.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{DynamicResource PanelBorderStyle}"
                Margin="0,0,0,10"
                Padding="10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Session"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Margin="0,0,10,0" />

                <Button Command="{Binding SaveSetupCommand}"
                        Content="Save Setup"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Command="{Binding LoadSetupCommand}"
                        Content="Load Setup"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />

                <CheckBox Content="Snapping"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsSnappingEnabled, Mode=TwoWay}"
                          Foreground="{DynamicResource Brush.TextPrimary}" />

                <Button Command="{Binding ToggleSpoutCommand}"
                        DockPanel.Dock="Right"
                        Padding="12,8"
                        Margin="8,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SuccessButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SpoutEnabled}" Value="True">
                                    <Setter Property="Background" Value="#d2691e" />
                                    <Setter Property="Content" Value="Spout Active" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SpoutEnabled}" Value="False">
                                    <Setter Property="Content" Value="Start Spout" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{DynamicResource PanelBorderStyle}" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Layers" Style="{DynamicResource PanelTitleStyle}" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Layers}"
                         SelectedItem="{Binding SelectedLayer}"
                         AllowDrop="True"
                         PreviewKeyDown="OnLayerListPreviewKeyDown"
                         PreviewMouseLeftButtonDown="OnLayerListPreviewMouseLeftButtonDown"
                         PreviewMouseMove="OnLayerListPreviewMouseMove"
                         DragOver="OnLayerListDragOver"
                         DragLeave="OnLayerListDragLeave"
                         Drop="OnLayerListDrop"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="12"
                         MinHeight="260">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName, Converter={StaticResource SingleLineTextConverter}}" Padding="8,6" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="12,0,12,12">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding AddLayerCommand}"
                                Content="Add Text" />
                        <Button Grid.Column="2"
                                Command="{Binding AddImageLayerCommand}"
                                Content="Add Image" />
                        <Button Grid.Column="4"
                                Command="{Binding DeleteLayerCommand}"
                                Content="Delete"
                                Style="{DynamicResource DangerButtonStyle}"
                                IsEnabled="{Binding SelectedLayer, Converter={StaticResource HasValueToBoolConverter}}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding MoveLayerUpCommand}"
                                Content="Move Up"
                                Style="{DynamicResource SuccessButtonStyle}"
                                IsEnabled="{Binding SelectedLayer, Converter={StaticResource HasValueToBoolConverter}}" />
                        <Button Grid.Column="2"
                                Command="{Binding MoveLayerDownCommand}"
                                Content="Move Down"
                                Style="{DynamicResource SuccessButtonStyle}"
                                IsEnabled="{Binding SelectedLayer, Converter={StaticResource HasValueToBoolConverter}}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource PanelBorderStyle}" Margin="0,0,10,0">
            <DockPanel LastChildFill="True">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                    <TextBlock Text="Preview (1920 x 1080)" 
                               Style="{DynamicResource PanelTitleStyle}" 
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center" />
                </DockPanel>
                <Viewbox Margin="12"
                         Stretch="Uniform"
                         StretchDirection="DownOnly"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Border Width="1920"
                            Height="1080"
                            x:Name="PreviewSurface"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#121419"
                            MouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
                            MouseMove="OnPreviewMouseMove"
                            MouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
                            MouseLeave="OnPreviewMouseLeave">
                        <Grid>
                            <Image Source="{Binding PreviewBitmap}" Stretch="Fill" />
                            <Path x:Name="PreviewLayerOutline"
                                  IsHitTestVisible="False"
                                  Visibility="Collapsed"
                                  Fill="#22000000"
                                  Stroke="#FF4F9DFF"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Grid>
                    </Border>
                </Viewbox>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{DynamicResource PanelBorderStyle}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="Layer Properties" Style="{DynamicResource PanelTitleStyle}" />

                <ScrollViewer x:Name="LayerPropertiesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalContentAlignment="Stretch"
                              Visibility="{Binding SelectedLayer, Converter={StaticResource SelectedLayerToVisibilityConverter}}">
                    <Border Padding="0,0,12,0">
                    <StackPanel Margin="12,12,0,0"
                                HorizontalAlignment="Stretch">
                        <StackPanel Style="{StaticResource TextLayerSectionStyle}">
                            <Expander Header="Text Content" Style="{StaticResource PropertySectionExpanderStyle}" IsExpanded="True">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Text" Style="{DynamicResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding SelectedText, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Height="84"
                                             HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Expander>

                            <Expander Header="Typography" Style="{StaticResource PropertySectionExpanderStyle}" IsExpanded="True">
                                <StackPanel Margin="0,8,0,0">
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Font Family" Style="{DynamicResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                                  SelectedItem="{Binding SelectedFontFamily, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Font Size (preset or custom)" Style="{DynamicResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding FontSizePresets}"
                                                  IsEditable="False"
                                                  SelectedItem="{Binding SelectedFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="Text Alignment" Style="{DynamicResource FieldLabelStyle}" />
                                        <UniformGrid Columns="3">
                                            <ToggleButton Content="Left"
                                                          Style="{StaticResource AlignmentToggleButtonStyle}"
                                                          IsChecked="{Binding IsTextAlignLeft, Mode=TwoWay}" />
                                            <ToggleButton Content="Center"
                                                          Style="{StaticResource AlignmentToggleButtonStyle}"
                                                          IsChecked="{Binding IsTextAlignCenter, Mode=TwoWay}" />
                                            <ToggleButton Content="Right"
                                                          Margin="0"
                                                          Style="{StaticResource AlignmentToggleButtonStyle}"
                                                          IsChecked="{Binding IsTextAlignRight, Mode=TwoWay}" />
                                        </UniformGrid>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Line Height (preset or custom)" Style="{DynamicResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding LineHeightPresets}"
                                                  IsEditable="False"
                                                  SelectedItem="{Binding SelectedLineHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Appearance" Style="{StaticResource PropertySectionExpanderStyle}">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Fill Color" Style="{DynamicResource FieldLabelStyle}" />
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="42"
                                                   Height="42"
                                                   Fill="{Binding SelectedFillColor, Converter={StaticResource ColorToBrushConverter}}"
                                                   Stroke="{DynamicResource Brush.Border}"
                                                   StrokeThickness="1"
                                                   Margin="0,0,10,0" />
                                        <Button Content="Choose Color"
                                                Width="130"
                                                VerticalAlignment="Center"
                                                Click="OnChooseFillColor" />
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <Expander Header="Outline" Style="{StaticResource PropertySectionExpanderStyle}">
                                <StackPanel Margin="0,8,0,0">
                                    <CheckBox IsChecked="{Binding SelectedOutlineEnabled, UpdateSourceTrigger=PropertyChanged}"
                                              Content="Enable Outline"
                                              Margin="0,0,0,10" />

                                    <StackPanel Margin="0,0,0,12" Opacity="{Binding SelectedOutlineEnabled}">
                                        <TextBlock Text="Outline Color" Style="{DynamicResource FieldLabelStyle}" />
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="42"
                                                       Height="42"
                                                       Fill="{Binding SelectedOutlineColor, Converter={StaticResource ColorToBrushConverter}}"
                                                       Stroke="{DynamicResource Brush.Border}"
                                                       StrokeThickness="1"
                                                       Margin="0,0,10,0" />
                                            <Button Content="Choose Color"
                                                    Width="130"
                                                    VerticalAlignment="Center"
                                                    Click="OnChooseOutlineColor" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Style="{StaticResource PropertyRowCompactStyle}">
                                        <TextBlock Text="Outline Thickness" Style="{DynamicResource FieldLabelStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="250" />
                                                <ColumnDefinition Width="56" />
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Style="{StaticResource PropertySliderStyle}"
                                                    Value="{Binding SelectedOutlineThickness, UpdateSourceTrigger=PropertyChanged}"
                                                    Minimum="0.5"
                                                    Maximum="20" />
                                            <TextBox Grid.Column="1"
                                                     Style="{StaticResource PropertyNumericTextBoxStyle}"
                                                     Text="{Binding SelectedOutlineThickness, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <StackPanel Style="{StaticResource ImageLayerSectionStyle}">
                            <Expander Header="Image" Style="{StaticResource PropertySectionExpanderStyle}" IsExpanded="True">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="Image File" Style="{DynamicResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding SelectedImagePath}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <Button Command="{Binding ReplaceImageCommand}" Content="Choose Image" Width="130" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>

                        <Expander Header="Transform" Style="{StaticResource PropertySectionExpanderStyle}">
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Style="{StaticResource PropertyRowStyle}">
                                    <TextBlock Text="Position X" Style="{DynamicResource FieldLabelStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource PropertySliderStyle}"
                                                Value="{Binding SelectedPositionX, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0"
                                                Maximum="1920" />
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource PropertyNumericTextBoxStyle}"
                                                 Text="{Binding SelectedPositionX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F0}" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Style="{StaticResource PropertyRowStyle}">
                                    <TextBlock Text="Position Y" Style="{DynamicResource FieldLabelStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource PropertySliderStyle}"
                                                Value="{Binding SelectedPositionY, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0"
                                                Maximum="1080" />
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource PropertyNumericTextBoxStyle}"
                                                 Text="{Binding SelectedPositionY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F0}" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Style="{StaticResource PropertyRowStyle}">
                                    <TextBlock Text="Scale X" Style="{DynamicResource FieldLabelStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource PropertySliderStyle}"
                                                Value="{Binding SelectedScaleX, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0.1"
                                                Maximum="3" />
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource PropertyNumericTextBoxStyle}"
                                                 Text="{Binding SelectedScaleX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Style="{StaticResource PropertyRowCompactStyle}">
                                    <TextBlock Text="Scale Y" Style="{DynamicResource FieldLabelStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="56" />
                                        </Grid.ColumnDefinitions>
                                        <Slider Grid.Column="0"
                                                Style="{StaticResource PropertySliderStyle}"
                                                Value="{Binding SelectedScaleY, UpdateSourceTrigger=PropertyChanged}"
                                                Minimum="0.1"
                                                Maximum="3" />
                                        <TextBox Grid.Column="1"
                                                 Style="{StaticResource PropertyNumericTextBoxStyle}"
                                                 Text="{Binding SelectedScaleY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}" />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                    </Border>
                </ScrollViewer>

                <TextBlock Text="No layer selected"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           FontSize="13"
                           Padding="14"
                           Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedLayer}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="2"
                Grid.ColumnSpan="3" Grid.Column="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                CornerRadius="6"
                Padding="12,8"
                Opacity="0.95"
                Panel.ZIndex="100">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource Brush.Success}" />
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastIsError}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Brush.Danger}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}"
                       Foreground="White"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</Window>
