<Window x:Class="SimpleSpoutOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:SimpleSpoutOverlay.UI.Converters"
        mc:Ignorable="d"
        Title="Spout Text Overlay"
        Height="840"
        Width="1460"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.WindowBackground}"
        MinHeight="700"
        MinWidth="1200">
    <Window.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <converters:HasValueToBoolConverter x:Key="HasValueToBoolConverter" />
        <converters:SelectedLayerToVisibilityConverter x:Key="SelectedLayerToVisibilityConverter" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Command="{Binding UndoCommand}" Key="Z" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding RedoCommand}" Key="Y" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding SaveSetupCommand}" Key="S" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding LoadSetupCommand}" Key="O" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding AddLayerCommand}" Key="N" Modifiers="Ctrl" />
        <KeyBinding Command="{Binding DeleteLayerCommand}" Key="Delete" Modifiers="Ctrl" />
    </Window.InputBindings>

    <Grid Margin="14" Background="{DynamicResource Brush.WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="290" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{DynamicResource PanelBorderStyle}"
                Margin="0,0,0,10"
                Padding="10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Session"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Margin="0,0,10,0" />

                <Button Command="{Binding SaveSetupCommand}"
                        Content="Save Setup"
                        Style="{DynamicResource SecondaryButtonStyle}"
                        Margin="0,0,8,0" />
                <Button Command="{Binding LoadSetupCommand}"
                        Content="Load Setup"
                        Style="{DynamicResource SecondaryButtonStyle}" />

                <Button Command="{Binding ToggleSpoutCommand}"
                        DockPanel.Dock="Right"
                        Padding="12,8"
                        Margin="8,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SuccessButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SpoutEnabled}" Value="True">
                                    <Setter Property="Background" Value="#d2691e" />
                                    <Setter Property="Content" Value="Spout Active" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SpoutEnabled}" Value="False">
                                    <Setter Property="Content" Value="Start Spout" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Style="{DynamicResource PanelBorderStyle}" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Layers" Style="{DynamicResource PanelTitleStyle}" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Layers}"
                         SelectedItem="{Binding SelectedLayer}"
                         AllowDrop="True"
                         PreviewKeyDown="OnLayerListPreviewKeyDown"
                         PreviewMouseLeftButtonDown="OnLayerListPreviewMouseLeftButtonDown"
                         PreviewMouseMove="OnLayerListPreviewMouseMove"
                         DragOver="OnLayerListDragOver"
                         DragLeave="OnLayerListDragLeave"
                         Drop="OnLayerListDrop"
                         Margin="12"
                         MinHeight="260">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Padding="8,6" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Margin="12,0,12,12">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding AddLayerCommand}"
                                Content="Add Text" />
                        <Button Grid.Column="2"
                                Command="{Binding AddImageLayerCommand}"
                                Content="Add Image" />
                        <Button Grid.Column="4"
                                Command="{Binding DeleteLayerCommand}"
                                Content="Delete"
                                Style="{DynamicResource DangerButtonStyle}"
                                IsEnabled="{Binding SelectedLayer, Converter={StaticResource HasValueToBoolConverter}}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding MoveLayerUpCommand}"
                                Content="Move Up"
                                Style="{DynamicResource SuccessButtonStyle}"
                                IsEnabled="{Binding SelectedLayer, Converter={StaticResource HasValueToBoolConverter}}" />
                        <Button Grid.Column="2"
                                Command="{Binding MoveLayerDownCommand}"
                                Content="Move Down"
                                Style="{DynamicResource SuccessButtonStyle}"
                                IsEnabled="{Binding SelectedLayer, Converter={StaticResource HasValueToBoolConverter}}" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource PanelBorderStyle}" Margin="0,0,10,0">
            <DockPanel LastChildFill="True">
                <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                    <TextBlock Text="Preview (1920 x 1080)" 
                               Style="{DynamicResource PanelTitleStyle}" 
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center" />
                </DockPanel>
                <Viewbox Margin="12"
                         Stretch="Uniform"
                         StretchDirection="DownOnly"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center">
                    <Border Width="1920"
                            Height="1080"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Background="#121419">
                        <Image Source="{Binding PreviewBitmap}" Stretch="Fill" />
                    </Border>
                </Viewbox>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Style="{DynamicResource PanelBorderStyle}">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" Text="Layer Properties" Style="{DynamicResource PanelTitleStyle}" />

                <ScrollViewer x:Name="LayerPropertiesScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              HorizontalContentAlignment="Stretch"
                              Visibility="{Binding SelectedLayer, Converter={StaticResource SelectedLayerToVisibilityConverter}}">
                    <Border Padding="0,0,12,0">
                    <StackPanel Margin="12,12,0,0"
                                HorizontalAlignment="Stretch">
                        <StackPanel Margin="0,0,0,14">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTextLayerSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Text" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SelectedText, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         Height="76"
                                         HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Font Family" Style="{DynamicResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding AvailableFonts}"
                                          SelectedItem="{Binding SelectedFontFamily, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Font Size" Style="{DynamicResource FieldLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Value="{Binding SelectedFontSize, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="8"
                                            Maximum="200"
                                            Thumb.DragStarted="OnPropertySliderDragStarted"
                                            Thumb.DragCompleted="OnPropertySliderDragCompleted"
                                            Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                             Style="{DynamicResource NumericValueEditorStyle}"
                                             Text="{Binding SelectedFontSize, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                             ToolTip="Click to type a value"
                                             GotKeyboardFocus="OnNumericEditorGotKeyboardFocus"
                                             KeyDown="OnNumericEditorKeyDown" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="Fill Color" Style="{DynamicResource FieldLabelStyle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="42"
                                               Height="42"
                                               Fill="{Binding SelectedFillColor, Converter={StaticResource ColorToBrushConverter}}"
                                               Stroke="{DynamicResource Brush.Border}"
                                               StrokeThickness="1"
                                               Margin="0,0,10,0" />
                                    <Button Content="Choose Color"
                                            Width="130"
                                            VerticalAlignment="Center"
                                            Click="OnChooseFillColor" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsImageLayerSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Image File" Style="{DynamicResource FieldLabelStyle}" />
                            <TextBox Text="{Binding SelectedImagePath}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <Button Command="{Binding ReplaceImageCommand}" Content="Choose Image" Width="130" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Position X" Style="{DynamicResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Value="{Binding SelectedPositionX, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0"
                                        Maximum="1920"
                                        Thumb.DragStarted="OnPropertySliderDragStarted"
                                        Thumb.DragCompleted="OnPropertySliderDragCompleted"
                                        Margin="0,0,8,0" />
                                <TextBox Grid.Column="1"
                                         Style="{DynamicResource NumericValueEditorStyle}"
                                         Text="{Binding SelectedPositionX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                         ToolTip="Click to type a value"
                                         GotKeyboardFocus="OnNumericEditorGotKeyboardFocus"
                                         KeyDown="OnNumericEditorKeyDown" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Position Y" Style="{DynamicResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Value="{Binding SelectedPositionY, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0"
                                        Maximum="1080"
                                        Thumb.DragStarted="OnPropertySliderDragStarted"
                                        Thumb.DragCompleted="OnPropertySliderDragCompleted"
                                        Margin="0,0,8,0" />
                                <TextBox Grid.Column="1"
                                         Style="{DynamicResource NumericValueEditorStyle}"
                                         Text="{Binding SelectedPositionY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F0}"
                                         ToolTip="Click to type a value"
                                         GotKeyboardFocus="OnNumericEditorGotKeyboardFocus"
                                         KeyDown="OnNumericEditorKeyDown" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Scale X" Style="{DynamicResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Value="{Binding SelectedScaleX, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0.1"
                                        Maximum="3"
                                        Thumb.DragStarted="OnPropertySliderDragStarted"
                                        Thumb.DragCompleted="OnPropertySliderDragCompleted"
                                        Margin="0,0,8,0" />
                                <TextBox Grid.Column="1"
                                         Style="{DynamicResource NumericValueEditorStyle}"
                                         Text="{Binding SelectedScaleX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         ToolTip="Click to type a value"
                                         GotKeyboardFocus="OnNumericEditorGotKeyboardFocus"
                                         KeyDown="OnNumericEditorKeyDown" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Scale Y" Style="{DynamicResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider Grid.Column="0"
                                        Value="{Binding SelectedScaleY, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0.1"
                                        Maximum="3"
                                        Thumb.DragStarted="OnPropertySliderDragStarted"
                                        Thumb.DragCompleted="OnPropertySliderDragCompleted"
                                        Margin="0,0,8,0" />
                                <TextBox Grid.Column="1"
                                         Style="{DynamicResource NumericValueEditorStyle}"
                                         Text="{Binding SelectedScaleY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}"
                                         ToolTip="Click to type a value"
                                         GotKeyboardFocus="OnNumericEditorGotKeyboardFocus"
                                         KeyDown="OnNumericEditorKeyDown" />
                            </Grid>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTextLayerSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <CheckBox IsChecked="{Binding SelectedOutlineEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      Content="Enable Outline"
                                      Margin="0,0,0,14" />

                            <StackPanel Margin="0,0,0,14" Opacity="{Binding SelectedOutlineEnabled}">
                                <TextBlock Text="Outline Color" Style="{DynamicResource FieldLabelStyle}" />
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="42"
                                               Height="42"
                                               Fill="{Binding SelectedOutlineColor, Converter={StaticResource ColorToBrushConverter}}"
                                               Stroke="{DynamicResource Brush.Border}"
                                               StrokeThickness="1"
                                               Margin="0,0,10,0" />
                                    <Button Content="Choose Color"
                                            Width="130"
                                            VerticalAlignment="Center"
                                            Click="OnChooseOutlineColor" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Text="Outline Thickness" Style="{DynamicResource FieldLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="250" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Value="{Binding SelectedOutlineThickness, UpdateSourceTrigger=PropertyChanged}"
                                            Minimum="0.5"
                                            Maximum="20"
                                            Thumb.DragStarted="OnPropertySliderDragStarted"
                                            Thumb.DragCompleted="OnPropertySliderDragCompleted"
                                            Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                             Style="{DynamicResource NumericValueEditorStyle}"
                                             Text="{Binding SelectedOutlineThickness, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F1}"
                                             ToolTip="Click to type a value"
                                             GotKeyboardFocus="OnNumericEditorGotKeyboardFocus"
                                             KeyDown="OnNumericEditorKeyDown" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    </Border>
                </ScrollViewer>

                <TextBlock Text="No layer selected"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           FontSize="13"
                           Padding="14"
                           Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedLayer}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

        <Border Grid.RowSpan="2"
                Grid.ColumnSpan="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                CornerRadius="6"
                Padding="12,8"
                Opacity="0.95"
                Panel.ZIndex="100">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource Brush.Success}" />
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastIsError}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Brush.Danger}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ToastMessage}"
                       Foreground="White"
                       FontWeight="SemiBold" />
        </Border>
    </Grid>
</Window>
