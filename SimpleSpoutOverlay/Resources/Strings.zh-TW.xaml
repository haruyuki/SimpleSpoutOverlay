<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- Panel and UI Labels -->
    <system:String x:Key="Label.Layers">圖層</system:String>
    <system:String x:Key="Label.Preview">預覽 (1920 x 1080)</system:String>
    <system:String x:Key="Label.LayerProperties">圖層屬性</system:String>
    <system:String x:Key="Label.NoLayerSelected">未選擇圖層</system:String>

    <!-- Session Controls -->
    <system:String x:Key="Label.Session">工作階段</system:String>
    <system:String x:Key="Button.Snapping">對齊吸附</system:String>
    <system:String x:Key="Button.StartSpout">啟動 Spout</system:String>
    <system:String x:Key="Button.SpoutActive">Spout 已激活</system:String>
    <system:String x:Key="Button.Language">語言</system:String>

    <!-- Text Layer Properties -->
    <system:String x:Key="Expander.TextContent">文本內容</system:String>
    <system:String x:Key="Label.Text">文本</system:String>
    <system:String x:Key="Expander.Typography">排版</system:String>
    <system:String x:Key="Label.FontFamily">字體</system:String>
    <system:String x:Key="Label.FontSize">字體大小</system:String>
    <system:String x:Key="Label.TextAlignment">文本對齊</system:String>
    <system:String x:Key="Label.LineHeight">行高</system:String>
    <system:String x:Key="Expander.Appearance">外觀</system:String>
    <system:String x:Key="Label.FillColor">填充顏色</system:String>
    <system:String x:Key="Button.ChooseColor">選擇顏色</system:String>
    <system:String x:Key="Expander.Outline">輪廓</system:String>
    <system:String x:Key="CheckBox.EnableOutline">啟用輪廓</system:String>
    <system:String x:Key="Label.OutlineColor">輪廓顏色</system:String>
    <system:String x:Key="Label.OutlineThickness">輪廓厚度</system:String>

    <!-- Image Layer Properties -->
    <system:String x:Key="Expander.Image">圖像</system:String>
    <system:String x:Key="Label.ImageFile">圖像檔案</system:String>
    <system:String x:Key="Button.ChooseImage">選擇圖像</system:String>

    <!-- Transform Properties -->
    <system:String x:Key="Expander.Transform">變換</system:String>
    <system:String x:Key="Label.PositionX">位置 X</system:String>
    <system:String x:Key="Label.PositionY">位置 Y</system:String>
    <system:String x:Key="Label.ScaleX">縮放 X</system:String>
    <system:String x:Key="Label.ScaleY">縮放 Y</system:String>

    <!-- Toast Messages -->
    <system:String x:Key="Toast.SetupSaved">設置已保存：{0}</system:String>
    <system:String x:Key="Toast.SetupLoaded">設置已載入：{0}</system:String>
    <system:String x:Key="Toast.FailedToSaveSetup">保存設置檔案失敗。</system:String>
    <system:String x:Key="Toast.FailedToLoadSetup">載入設置檔案失敗。</system:String>
    <system:String x:Key="Toast.InvalidSetupFile">設置檔案無效或為空。</system:String>
    <system:String x:Key="Toast.ImageAdded">圖像已新增：{0}</system:String>
    <system:String x:Key="Toast.ImageUpdated">圖像已更新：{0}</system:String>
</ResourceDictionary>



